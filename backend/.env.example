# Application
PORT=8080
ENVIRONMENT=production

# CORS
ALLOWED_ORIGINS=*

# Cookies
COOKIE_DOMAINS=
SECURE_COOKIE=true

# Database
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/much_todo_db?retryWrites=true&w=majority
DB_NAME=much_todo_db

# Authentication
JWT_SECRET_KEY=change-me-to-a-very-long-random-string
JWT_EXPIRATION_HOURS=72

# Caching
ENABLE_CACHE=true
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Testing
INTEGRATION=false
